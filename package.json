{
  "name": "volt-game",
  "version": "1.1.0",
  "description": "VOLT — One Tap. Pure Reflex. A viral neon arcade game.",
  "private": true,
  "scripts": {
    "cap:add": "cap add android",
    "cap:sync": "cap sync android",
    "assets": "capacitor-assets generate --android --iconBackgroundColor #05060a --iconBackgroundColorDark #05060a --splashBackgroundColor #05060a --splashBackgroundColorDark #05060a",
    "apk": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "6.1.2",
    "@capacitor/app": "6.0.2",
    "@capacitor/core": "6.1.2",
    "@capacitor/ios": "6.1.2",
    "@capacitor/status-bar": "6.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "6.1.2"
  }
}
